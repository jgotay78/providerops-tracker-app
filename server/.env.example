# ProviderOps Tracker backend
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
FROM_EMAIL="ProviderOps Tracker <no-reply@providerops.local>"
REPLY_TO_EMAIL=credentialing@providerops.local

# Optional real SMTP settings. If these are blank, Nodemailer uses demo-json mode.
# For Gmail, use an app password, not your normal account password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
